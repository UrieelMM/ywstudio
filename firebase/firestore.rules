rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    // Permite operar con claim de tenant o con tenant fijo de proyecto.
    function hasTenantClaim(tenantId) {
      return request.auth.token.tenantId != null
        && request.auth.token.tenantId == tenantId;
    }

    function isProjectTenant(tenantId) {
      return tenantId == 'tenant-ywstudio';
    }

    function hasTenantAccess(tenantId) {
      return isAuthenticated() && (hasTenantClaim(tenantId) || isProjectTenant(tenantId));
    }

    function hasAuditFields() {
      return request.resource.data.createdAtCustom is string
        && request.resource.data.updatedAtCustom is string
        && request.resource.data.createdBy is string
        && request.resource.data.updatedBy is string;
    }

    function tenantMatches(tenantId) {
      return request.resource.data.tenantId is string
        && request.resource.data.tenantId == tenantId;
    }

    match /tenants/{tenantId} {
      allow read: if hasTenantAccess(tenantId);
      allow create, update, delete: if false;
    }

    // Usuarios del programa
    match /tenants/{tenantId}/users/{userId} {
      allow read: if hasTenantAccess(tenantId);
      allow create, update: if hasTenantAccess(tenantId)
        && tenantMatches(tenantId)
        && hasAuditFields();
      allow delete: if hasTenantAccess(tenantId);
    }

    // Campañas QR (lectura pública para /scan/:qrCodeId)
    match /tenants/{tenantId}/qrCodes/{qrCodeId} {
      allow read: if hasTenantAccess(tenantId)
        || isProjectTenant(tenantId);
      allow create, update: if hasTenantAccess(tenantId)
        && tenantMatches(tenantId)
        && hasAuditFields();
      allow delete: if hasTenantAccess(tenantId);
    }

    // Configuración general (logo, sedes, disciplinas, adminName)
    // Lectura pública para pantalla de login y escaneo público.
    match /tenants/{tenantId}/config/{docId} {
      allow read: if hasTenantAccess(tenantId)
        || isProjectTenant(tenantId);
      allow create, update: if hasTenantAccess(tenantId)
        && tenantMatches(tenantId)
        && hasAuditFields();
      allow delete: if hasTenantAccess(tenantId);
    }

    // Otras colecciones operativas del tenant
    match /tenants/{tenantId}/{collectionName}/{docId} {
      allow read: if hasTenantAccess(tenantId);
      allow create, update: if hasTenantAccess(tenantId)
        && tenantMatches(tenantId)
        && hasAuditFields();
      allow delete: if hasTenantAccess(tenantId);
    }
  }
}
